.TH "GSCAN" "1" "Apr 2026" "gscan dev" "gscan Manual"

.SH NAME
gscan - Fast IP/port scanner


.SH SYNOPSIS
\fBgscan [TARGETS...] [flags]\fP


.SH DESCRIPTION
gscan is a fast TCP/IP scanner with TCP-connect probes, bounded concurrency, and optional banner grab.


.SH OPTIONS
\fB--banner\fP[=false]
	Grab a short service banner on open ports

.PP
\fB--concurrency\fP=1000
	Max parallel sockets in flight

.PP
\fB--down\fP[=false]
	Only show hosts with no open ports

.PP
\fB--exclude\fP=[]
	Addresses/ranges/CIDRs to skip (comma-separated, repeatable)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for gscan

.PP
\fB--max-hosts\fP=50
	Max hosts probed in parallel

.PP
\fB--no-color\fP[=false]
	Disable ANSI colour in human output

.PP
\fB--no-dns\fP[=false]
	Skip reverse DNS lookups

.PP
\fB--no-progress\fP[=false]
	Disable the stderr progress bar

.PP
\fB-o\fP, \fB--output\fP="human"
	Output format: human | json | grep

.PP
\fB--ping-only\fP[=false]
	Host discovery only, no port scan

.PP
\fB-p\fP, \fB--ports\fP=""
	Ports: 22 | 22,80 | 1-1024 | - | top100 | top1000

.PP
\fB--retries\fP=1
	Retries on filtered (timeout) probes

.PP
\fB--script\fP=[]
	Lua script to run against open ports (repeatable)

.PP
\fB--script-timeout\fP=5s
	Per-invocation timeout for --script

.PP
\fB--sn\fP[=false]
	Alias for --ping-only (nmap-style)

.PP
\fB--timeout\fP=1.5s
	Per-probe dial timeout

.PP
\fB--up\fP[=false]
	Only show hosts with at least one open port

.PP
\fB-v\fP, \fB--verbose\fP[=0]
	Verbose output (-v shows closed/filtered, -vv shows errors too)


.SH EXAMPLE
.EX
  gscan 127.0.0.1 -p 22
  gscan 192.168.1.0/24 -p top100 --up
  gscan 10.0.0.1-50 -p 22,80,443 --banner
  gscan 10.0.0.0/24 --sn               # host discovery only (alias for --ping-only)
  gscan example.com -p- --timeout 300ms
.EE


