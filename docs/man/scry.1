.nh
.TH "SCRY" "1" "Apr 2026" "scry dev" "scry Manual"

.SH NAME
scry - Fast IP/port scanner


.SH SYNOPSIS
\fBscry [TARGETS...] [flags]\fP


.SH DESCRIPTION
scry is a fast TCP/IP scanner with TCP-connect probes, bounded concurrency, and optional banner grab.


.SH OPTIONS
\fB--banner\fP[=false]
	Grab a short service banner on open ports

.PP
\fB--concurrency\fP=2000
	Max parallel sockets in flight (lower if hitting RLIMIT_NOFILE)

.PP
\fB--down\fP[=false]
	Only show hosts with no open ports

.PP
\fB--exclude\fP=[]
	Addresses/ranges/CIDRs to skip (comma-separated, repeatable)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for scry

.PP
\fB--list-scripts\fP[=false]
	Print metadata for scripts passed via --script and exit

.PP
\fB--max-hosts\fP=100
	Max hosts probed in parallel

.PP
\fB--no-color\fP[=false]
	Disable ANSI colour in human output

.PP
\fB--no-dns\fP[=false]
	Skip reverse DNS lookups

.PP
\fB--no-progress\fP[=false]
	Disable the stderr progress bar

.PP
\fB-o\fP, \fB--output\fP="human"
	Output format: human | json | grep

.PP
\fB--ping-only\fP[=false]
	Host discovery only, no port scan

.PP
\fB-p\fP, \fB--ports\fP=""
	Ports: 22 | 22,80 | 1-1024 | - | top100 | top1000

.PP
\fB--retries\fP=0
	Retries on filtered (timeout) probes (set 1+ for accuracy on lossy links)

.PP
\fB--script\fP=[]
	Lua script to run against open ports (repeatable)

.PP
\fB--script-timeout\fP=5s
	Per-invocation timeout for --script

.PP
\fB--sn\fP[=false]
	Alias for --ping-only (nmap-style)

.PP
\fB--syn\fP[=false]
	Use raw SYN scanner (requires -tags rawsock build + CAP_NET_RAW)

.PP
\fB--timeout\fP=500ms
	Per-probe dial timeout (bump for WAN or high-latency links)

.PP
\fB--up\fP[=false]
	Only show hosts with at least one open port

.PP
\fB-v\fP, \fB--verbose\fP[=0]
	Verbose output (-v shows closed/filtered, -vv shows errors too)


.SH EXAMPLE
.EX
  scry 127.0.0.1 -p 22
  scry 192.168.1.0/24 -p top100 --up
  scry 10.0.0.1-50 -p 22,80,443 --banner
  scry 10.0.0.0/24 --sn               # host discovery only (alias for --ping-only)
  scry example.com -p- --timeout 300ms
.EE


